VITE_API_URL=https://myschoolprojectbackend.onrender.com/api

# Narration:
# - browser: uses Web Speech API (no keys; quality varies)
# - remote: calls your backend TTS endpoint (best quality; keys stay server-side)
VITE_TTS_MODE=remote
# Path appended to VITE_API_URL, e.g. http://localhost:5000/api + /tts/speak
VITE_TTS_PATH=/tts/speak

VITE_ADMIN_ENABLED=true